# ─── Notion ────────────────────────────────────────────────────────────────────
NOTION_TOKEN=your_notion_integration_token
SOURCES_DB_ID=your_sources_database_id
DAILY_BRIEFS_DB_ID=your_daily_briefs_database_id
WEEKLY_SYNTHESIS_DB_ID=your_weekly_synthesis_database_id

# ─── Gemini ─────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Gmail OAuth (created once in Google Cloud Console) ─────────────────────────
GMAIL_CLIENT_ID=your_gmail_oauth_client_id
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret

# ─── Ollama ──────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=your_local_model_name

# ─── AI routing — change to "ollama" to switch providers globally ─────────────────
# Both workflows pick this up on next run. No workflow edits needed.
AI_PROVIDER=gemini
