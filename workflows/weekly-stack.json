    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const d = $input.first().json;\nconst results = d.results || [];\nconst brief_date = $('Tag Brief Page').item.json.brief_date || '';\nconst page_id    = $('Tag Brief Page').item.json.page_id || '';\n\nconst parts = [];\nfor (const block of results) {\n  const type = block.type;\n  if (!type) continue;\n  const rt = block[type]?.rich_text || [];\n  const text = rt.map(r => r.plain_text || '').join('');\n  if (!text.trim()) continue;\n  if (type === 'heading_2') parts.push('## ' + text);\n  else if (type === 'heading_3') parts.push('### ' + text);\n  else if (type === 'bulleted_list_item') parts.push('- ' + text);\n  else parts.push(text);\n}\n\nreturn [{ json: { page_id, brief_date, brief_text: parts.join('\\n') } }];"
      },
      "id": "cb32cbec-7d61-4742-ac96-b91a04eebe3b",
      "name": "Extract Brief Text",
      "type": "n8n-nodes-base.code",
