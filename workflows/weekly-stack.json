      "id": "65cb589e-3e22-4d05-b5a9-cdd69ab2ec42",
      "name": "Call Ollama (W)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        4120,
        360
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst d = items[0].json;\nlet ai_text = '';\nlet provider_used = 'Unknown';\n\nif (d.candidates && Array.isArray(d.candidates) && d.candidates[0]) {\n  const parts = d.candidates[0]?.content?.parts || [];\n  ai_text = parts.map(p => p.text || '').join('');\n  provider_used = 'Gemini';\n} else if (d.message && d.message.content !== undefined) {\n  ai_text = d.message.content;\n  provider_used = 'Ollama';\n} else if (d.response !== undefined) {\n  ai_text = d.response;\n  provider_used = 'Ollama';\n} else if (d.ai_text !== undefined) {\n  ai_text = d.ai_text;\n  provider_used = d.provider_used || 'Unknown';\n}\n\nconst item_count = $input.first().json.item_count ?? 0;\n\nreturn [{ json: { ai_text, provider_used, item_count } }];"
      },
      "id": "427f7ef9-5f39-4544-8dda-77fa6ee9946c",
      "name": "Normalise AI Response (W)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        4360,
        260
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const { ai_text, provider_used, item_count } = $input.first().json;\nconst blocks = [];\n\nfor (const line of (ai_text || '').split('\\n')) {\n  const t = line.trim();\n  if (!t) continue;\n  if (t.startsWith('## ')) {\n    blocks.push({ object: 'block', type: 'heading_2',\n      heading_2: { rich_text: [{ type: 'text', text: { content: t.slice(3) } }], color: 'default' } });\n  } else if (t.startsWith('### ')) {\n    blocks.push({ object: 'block', type: 'heading_3',\n      heading_3: { rich_text: [{ type: 'text', text: { content: t.slice(4) } }], color: 'default' } });\n  } else if (t.startsWith('- ') || t.startsWith('* ')) {\n    blocks.push({ object: 'block', type: 'bulleted_list_item',\n      bulleted_list_item: { rich_text: [{ type: 'text', text: { content: t.slice(2) } }], color: 'default' } });\n  } else {\n    blocks.push({ object: 'block', type: 'paragraph',\n      paragraph: { rich_text: [{ type: 'text', text: { content: t } }], color: 'default' } });\n  }\n}\n\nreturn [{ json: { ai_text, provider_used, item_count, blocks: blocks.slice(0, 95) } }];"
      },
      "id": "26280804-13e4-46e5-b535-e033122b7b92",
      "name": "Build Notion Blocks (W)",
