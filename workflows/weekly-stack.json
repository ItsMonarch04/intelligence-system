        390
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst briefs = items\n  .map(item => {\n    const { brief_date, brief_text } = item.json;\n    return brief_text ? '=== ' + brief_date + ' ===\\n' + brief_text : null;\n  })\n  .filter(Boolean);\n\nreturn [{ json: {\n  all_briefs_text: briefs.join('\\n\\n'),\n  brief_count: briefs.length\n} }];"
      },
