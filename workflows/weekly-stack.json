    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const allItems = $input.all();\nconst seen = new Set();\nconst normalised = [];\n\nfor (const item of allItems) {\n  const d = item.json;\n  let source_type = d._type || '';\n  let source_name = '';\n  let title = '';\n  let snippet = '';\n\n  if (d.subject !== undefined) {\n    source_type = source_type || 'Newsletter';\n    source_name = String(d.from || 'Newsletter').replace(/<[^>]*>/g, '').trim();\n    title = String(d.subject || '(no subject)');\n    snippet = String(d.text || d.snippet || '').replace(/\\s+/g, ' ').trim().substring(0, 600);\n  } else if (d.title !== undefined && (d.link !== undefined || d.guid !== undefined)) {\n    source_type = source_type || 'News';\n    source_name = String(d.creator || d.author || d['dc:creator'] || 'RSS');\n    title = String(d.title || '');\n    snippet = String(d.contentSnippet || d.content || d.description || '')\n      .replace(/<[^>]*>/g, '').replace(/\\s+/g, ' ').trim().substring(0, 400);\n  } else {\n    source_type = 'Unknown';\n    source_name = 'Unknown';\n    title = JSON.stringify(d).substring(0, 80);\n  }\n\n  const key = title.toLowerCase().trim();\n  if (key && !seen.has(key)) {\n    seen.add(key);\n    normalised.push({ source_type, source_name, title, snippet });\n  }\n}\n\nconst weekly_items_text = normalised\n  .map(i => '[' + i.source_type + '] ' + i.source_name + '\\n' + i.title + '\\n' + i.snippet)\n  .join('\\n\\n---\\n\\n');\n\nreturn [{ json: { weekly_items: normalised, weekly_item_count: normalised.length, weekly_items_text } }];"
      },
      "id": "81048fae-fd95-4a68-8200-77c56dcae7e5",
      "name": "Normalise Weekly Sources",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2920,
        390
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const d = $input.first().json;\nconst weekly_items_text   = d.weekly_items_text   || '';\nconst weekly_item_count   = d.weekly_item_count   || 0;\n\nlet all_briefs_text = '';\nlet brief_count = 0;\ntry {\n  const agg = $('Aggregate All Briefs').first().json;\n  all_briefs_text = agg.all_briefs_text || '';\n  brief_count     = agg.brief_count     || 0;\n} catch(e) {\n  all_briefs_text = '(No daily briefs available this week)';\n}\n\nconst has_content = brief_count > 0 || weekly_item_count > 0;\n\nconst prompt =\n  'You are a personal knowledge curator reviewing a full week of content.\\n\\n'\n  + 'Inputs below:\\n'\n  + '1. Daily briefs from this week\\n'\n  + '2. Weekly-cadence sources published this week\\n\\n'\n  + 'Produce a Weekly Synthesis in exactly this structure:\\n\\n'\n  + '## The Week\\'s Signal\\n'\n  + 'The single most important theme or development this week. 2-3 sentences.\\n\\n'\n  + '## Three Things That Mattered\\n'\n  + 'The 3 developments with the most lasting relevance.\\n'\n  + 'For each: **What happened** \\u2014 Why it matters beyond this week.\\n\\n'\n  + '## Patterns Worth Noting\\n'\n  + 'Any signal that appeared across multiple days or sources.\\n'\n  + 'What does the repetition suggest?\\n\\n'\n  + '## Carry Into Next Week\\n'\n  + '2-3 things to keep in mind or follow up on.\\n\\n'\n  + '## What You Can Let Go\\n'\n  + 'Noise that dominated coverage this week but won\\'t matter in a month.\\n\\n'\n  + '---\\n'\n  + 'DAILY BRIEFS THIS WEEK:\\n'\n  + (all_briefs_text || '(No daily briefs this week)')\n  + '\\n\\nWEEKLY SOURCES:\\n'\n  + (weekly_items_text || '(No weekly sources this week)')\n  + '\\n\\nBe direct. Prioritise signal over summary.';\n\nreturn [{ json: { prompt, has_content, brief_count, weekly_item_count } }];"
      },
