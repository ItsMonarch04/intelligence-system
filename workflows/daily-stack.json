    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.OLLAMA_HOST + '/api/chat' }}",
        "authentication": "none",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ { model: $env.OLLAMA_MODEL, messages:[{ role:\"user\", content: $json.prompt }], stream: false } }}",
        "options": {
