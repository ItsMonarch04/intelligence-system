      "id": "4533e3e5-6257-45be-9daa-1564a6285e15",
      "name": "Route to AI",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        2420,
        240
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=' + $env.GEMINI_API_KEY }}",
        "authentication": "none",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ { contents:[{ parts:[{ text: $json.prompt }] }], generationConfig:{ maxOutputTokens:1500, temperature:0.3 } } }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          },
          "timeout": 45000,
          "onError": "continueErrorOutput"
        }
      },
      "id": "5d47b9b6-0565-498a-a0ca-dccd616eec89",
      "name": "Call Gemini",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2660,
        160
