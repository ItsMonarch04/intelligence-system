      "id": "f84b5cd1-c8f6-4f85-a636-d006f7c11567",
      "name": "Guard: Has Items?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1700,
        390
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const allItems = $input.all();\nconst seen = new Set();\nconst normalised = [];\n\nfor (const item of allItems) {\n  const d = item.json;\n  let source_type = d._type || '';\n  let source_name = '';\n  let title = '';\n  let snippet = '';\n\n  if (d.subject !== undefined) {\n    // Gmail message\n    source_type = source_type || 'Newsletter';\n    source_name = String(d.from || 'Newsletter').replace(/<[^>]*>/g, '').trim();\n    title = String(d.subject || '(no subject)');\n    snippet = String(d.text || d.snippet || '').replace(/\\s+/g, ' ').trim().substring(0, 600);\n  } else if (d.title !== undefined && (d.link !== undefined || d.guid !== undefined)) {\n    // RSS / Atom item\n    source_type = source_type || 'News';\n    source_name = String(d.creator || d.author || d['dc:creator'] || 'RSS');\n    title = String(d.title || '');\n    snippet = String(d.contentSnippet || d.content || d.description || '')\n      .replace(/<[^>]*>/g, '').replace(/\\s+/g, ' ').trim().substring(0, 400);\n  } else {\n    source_type = 'Unknown';\n    source_name = 'Unknown';\n    title = JSON.stringify(d).substring(0, 80);\n  }\n\n  const key = title.toLowerCase().trim();\n  if (key && !seen.has(key)) {\n    seen.add(key);\n    normalised.push({ source_type, source_name, title, snippet });\n  }\n}\n\nconst content = normalised\n  .map(i => '[' + i.source_type + '] ' + i.source_name + '\\nHeadline: ' + i.title + '\\n' + i.snippet)\n  .join('\\n\\n---\\n\\n');\n\nconst prompt =\n  'You are a personal knowledge curator. Below are today\\'s newsletters, news items, and podcast episodes.\\n\\n'\n  + 'Produce a Morning Brief in exactly this structure:\\n\\n'\n  + '## Today in Brief\\n'\n  + '2-3 sentence overview of the single most important signal today.\\n\\n'\n  + '## Key Insights\\n'\n  + 'Top 5 insights across all sources. For each:\\n'\n  + '**[Source]** \\u2014 Insight in one sentence. Why it matters in one sentence.\\n\\n'\n  + '## Follow Up On\\n'\n  + 'Actionable items only. Skip this section entirely if none.\\n\\n'\n  + '## Safe to Skip Today\\n'\n  + 'Sources that published nothing meaningfully new. One line each.\\n\\n'\n  + '---\\nCONTENT:\\n'\n  + content\n  + '\\n\\nBe direct. No filler. Prioritise signal over coverage.';\n\nreturn [{ json: { prompt, item_count: normalised.length } }];"
      },
      "id": "0404f2d2-c4b8-4392-be46-ab30cd521676",
      "name": "Normalise + Build Prompt",
